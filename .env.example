# Aethor — miljøvariabler
# Kopier denne filen til .env.local og fyll inn verdiene
# .env.local skal ALDRI committes (se .gitignore)

# --- Kreves ikke (åpne APIer uten nøkkel) ---
VITE_POLITILOGGEN_BASE=https://api.politiet.no/politiloggen/v1
VITE_MET_API_BASE=https://api.met.no/weatherapi
VITE_VEGVESEN_BASE=https://webkamera.vegvesen.no/public

# --- Valgfritt (gratis registrering) ---
# OpenCage geocoding: https://opencagedata.com (2500 req/dag gratis)
VITE_OPENCAGE_KEY=

# AIS Stream: https://aisstream.io (gratis tier)
VITE_AIS_API_KEY=

# --- App-konfig ---
VITE_APP_NAME=AETHOR
VITE_APP_ENV=development
